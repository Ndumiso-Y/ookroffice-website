# OOKR Office Website - Environment Configuration
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control

# =============================================================================
# PUBLIC URL CONFIGURATION
# =============================================================================
# Used by Create React App for asset paths and routing
# Development: Leave empty or set to /
# Production (root domain): PUBLIC_URL=/
# Production (subdirectory): PUBLIC_URL=/ookr
PUBLIC_URL=/

# =============================================================================
# EMAILJS CONFIGURATION
# =============================================================================
# Used for contact form submissions across all divisions
# Get your credentials from https://www.emailjs.com/
REACT_APP_EMAILJS_SERVICE_ID=your_service_id_here
REACT_APP_EMAILJS_TEMPLATE_ID=your_template_id_here
REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key_here

# =============================================================================
# FIREBASE CONFIGURATION (if needed in future)
# =============================================================================
# Uncomment and fill these if you add Firebase features
# REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
# REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# REACT_APP_FIREBASE_PROJECT_ID=your_project_id
# REACT_APP_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
# REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
# REACT_APP_FIREBASE_APP_ID=1:123456789:web:abcdef

# =============================================================================
# GOOGLE ANALYTICS (if needed in future)
# =============================================================================
# REACT_APP_GA_TRACKING_ID=UA-XXXXXXXXX-X

# =============================================================================
# API ENDPOINTS (if needed in future)
# =============================================================================
# REACT_APP_API_BASE_URL=https://api.ookroffice.com
# REACT_APP_API_TIMEOUT=5000

# =============================================================================
# FEATURE FLAGS (if needed)
# =============================================================================
# REACT_APP_ENABLE_ANALYTICS=true
# REACT_APP_ENABLE_CHAT=false
# REACT_APP_MAINTENANCE_MODE=false

# =============================================================================
# NOTES
# =============================================================================
# 1. All environment variables for Create React App MUST start with REACT_APP_
# 2. Changes to .env files require restarting the development server
# 3. PUBLIC_URL does not need the REACT_APP_ prefix
# 4. Never commit sensitive credentials to version control
# 5. Use .env.local for local development (automatically ignored by git)
# 6. Use .env.production for production builds (deploy separately)
